# ═══════════════════════════════════════════════════════
#  Redirect Manager – Ordner-Sicherheit
# ═══════════════════════════════════════════════════════

# ── Verzeichnislisting verbieten ────────────────────────
Options -Indexes

# ── Alles blockieren, nur index.php + callback.php erlaubt
<FilesMatch ".+">
    Require all denied
</FilesMatch>
<FilesMatch "^(index|callback|config|oidc|htaccess|view|check)\.php$">
    Require all granted
</FilesMatch>

# ── Security Headers ────────────────────────────────────
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "no-referrer"
Header always set X-Robots-Tag "noindex, nofollow, noarchive"
Header always set Cache-Control "no-store, no-cache, must-revalidate, private"
Header always set Pragma "no-cache"
