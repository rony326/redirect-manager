# ═══════════════════════════════════════════════════════
#  Redirect Manager – Folder Security
# ═══════════════════════════════════════════════════════

Options -Indexes

# Block sensitive file extensions (old-style, works everywhere)
<FilesMatch "\.(bak|log|sql|sh|env|ini|json|md|txt|zip|tar|gz|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security Headers (wrapped in IfModule so it never breaks)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set X-Robots-Tag "noindex, nofollow, noarchive"
    Header always set Cache-Control "no-store, no-cache, must-revalidate, private"
</IfModule>
